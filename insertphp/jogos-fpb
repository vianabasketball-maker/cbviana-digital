// --- RENDER CARD ---
function renderCard8d($j){
    $cb = 'https://sav2.fpb.pt/old_uploads/CLU/CLU_723_LOGO.jpg';
    $lc = !empty($j['lc']) ? $j['lc'] : $cb;
    $lf = !empty($j['lf']) ? $j['lf'] : $cb;
    $rc_col = $rf_col = '#333';
    $vence = false;
    if($j['ir'] && $j['rc']!==''){
        $vc = stripos($j['ec'],'viana')!==false;
        if(($vc&&intval($j['rc'])>intval($j['rf']))||(!$vc&&intval($j['rf'])>intval($j['rc']))) $vence=true;
        if(intval($j['rc'])>intval($j['rf'])){$rc_col='#155724';$rf_col='#721c24';}
        else{$rc_col='#721c24';$rf_col='#155724';}
    }
    if($j['ir'] && $j['rc']!==''){
        $centro = '<div style="text-align:center;min-width:80px;flex-shrink:0;">
            <span style="font-size:20px;font-weight:800;color:'.$rc_col.';">'.esc_html($j['rc']).'</span>
            <span style="color:#ddd;margin:0 2px;">-</span>
            <span style="font-size:20px;font-weight:800;color:'.$rf_col.';">'.esc_html($j['rf']).'</span>
            '.($vence?'<div style="font-size:9px;color:#155724;background:#d4edda;padding:1px 5px;border-radius:6px;display:inline-block;margin-top:2px;font-weight:700;">VITÓRIA</div>':'').'
        </div>';
    } else {
        $centro = '<div style="text-align:center;min-width:60px;flex-shrink:0;">
            '.($j['hora']?'<div style="font-size:14px;font-weight:800;color:#7b1c2e;">'.esc_html($j['hora']).'</div><div style="font-size:9px;color:#bbb;">VS</div>':'<div style="font-size:10px;color:#ccc;letter-spacing:2px;">VS</div>').'
        </div>';
    }
    return '<a href="'.esc_url($j['link']).'" target="_blank" class="cb-card">
        <div style="font-size:10px;color:#999;font-weight:600;min-width:55px;flex-shrink:0;">'.esc_html($j['data']).'</div>
        <div style="display:flex;align-items:center;gap:5px;flex:1;min-width:0;">
            <img src="'.esc_url($lc).'" style="width:24px;height:24px;object-fit:contain;flex-shrink:0;" onerror="this.src=\''.esc_url($cb).'\'">
            <span style="font-size:12px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;">'.esc_html($j['ec']).'</span>
        </div>
        '.$centro.'
        <div style="display:flex;align-items:center;gap:5px;flex:1;min-width:0;justify-content:flex-end;">
            <span style="font-size:12px;font-weight:700;overflow:hidden;text-overflow:ellipsis;white-space:nowrap;text-align:right;">'.esc_html($j['ef']).'</span>
            <img src="'.esc_url($lf).'" style="width:24px;height:24px;object-fit:contain;flex-shrink:0;" onerror="this.src=\''.esc_url($cb).'\'">
        </div>
    </a>';
}

