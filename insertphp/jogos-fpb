// --- PARSER ---
$_p8d = function($html) use(&$_ma8d) {
    $jogos = [];
    if(!$html) return $jogos;
    preg_match_all('/<div class="day-wrapper[^"]*">(.*?)<\/div>\s*<!-- END DAY ROW/si', $html, $days);
    foreach($days[1] as $db){
        preg_match('/<h3 class="date">\s*(.*?)\s*<\/h3>/si', $db, $dm);
        $data = isset($dm[1]) ? trim(strip_tags($dm[1])) : '';
        $ts = false;
        if(preg_match('/(\d{1,2})\s+([A-Z]{3})\s+(\d{4})/u', strtoupper($data), $tm)){
            $ts = strtotime($tm[3].'-'.($_ma8d[$tm[2]]??'01').'-'.str_pad($tm[1],2,'0',STR_PAD_LEFT));
        }
        preg_match_all('/<a href="(\/ficha-de-jogo[^"]*)"[^>]*>\s*<div class="game-wrapper([^"]*)">(.*?)<\/div>\s*<\/a>/si', $db, $games);
        foreach($games[3] as $idx=>$gb){
            $link = 'https://www.fpb.pt'.$games[1][$idx];
            $ir = strpos($games[2][$idx],'results') !== false;
            preg_match_all('/<div class="team-container[^"]*">(.*?)<\/div>\s*<\/div>/si', $gb, $teams);
            $ec=$ef=$lc=$lf='';
            if(isset($teams[1][0])){
                preg_match('/src="([^"]+)"/',$teams[1][0],$lm); $lc=$lm[1]??'';
                preg_match('/<span class="sigla">([^<]+)<\/span>/',$teams[1][0],$nm); $ec=isset($nm[1])?trim($nm[1]):'';
            }
            if(isset($teams[1][1])){
                preg_match('/src="([^"]+)"/',$teams[1][1],$lm2); $lf=$lm2[1]??'';
                preg_match('/<span class="sigla">([^<]+)<\/span>/',$teams[1][1],$nm2); $ef=isset($nm2[1])?trim($nm2[1]):'';
            }
            $rc=$rf='';
            if($ir){
                preg_match('/<div class="results_wrapper[^"]*">(.*?)<\/div>/si',$gb,$rw);
                if(isset($rw[1])){preg_match_all('/<h3[^>]*>\s*(\d+)\s*<\/h3>/',$rw[1],$sc);$rc=$sc[1][0]??'';$rf=$sc[1][1]??'';}
            }
            // Tenta o novo formato da FPB (div hour > h3)
if(preg_match('/<div[^>]*class="hour[^"]*"[^>]*>\s*<h3>\s*([^<]+)\s*<\/h3>/si', $gb, $hm)){
    $hora = trim($hm[1]);
    // Converte "15H30" para "15:30"
    if(preg_match('/^(\d{1,2})H(\d{2})$/i', $hora, $hc)) $hora = $hc[1].':'.$hc[2];
} else {
    // Fallback: se não encontrar o h3, tenta o span antigo
    preg_match('/<span class="hour">([^<]+)<\/span>/',$gb,$hm); 
    $hora = isset($hm[1]) ? trim($hm[1]) : '';
}
            preg_match('/<b>\s*(.*?)\s*<\/b>/si',$gb,$lm3); $local=isset($lm3[1])?trim(strip_tags($lm3[1])):'';
            preg_match('/class="competition"[^>]*>.*?<span>\s*(.*?)\s*<\/span>/si',$gb,$cm); $comp=isset($cm[1])?trim(strip_tags($cm[1])):'';
            $jogos[] = compact('data','ts','hora','ec','ef','lc','lf','rc','rf','local','comp','link','ir');
        }
    }
    return $jogos;
};

