/* Itens menu */
.cbv-menu{list-style:none;margin:0;padding:0;display:flex;align-items:center;flex:1;justify-content:center;}
.cbv-menu li{position:relative;}
.cbv-menu-a{font-family:var(--font);font-size:13px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.75);text-decoration:none;padding:0 10px;height:60px;display:flex;align-items:center;white-space:nowrap;position:relative;transition:color .2s;}
.cbv-menu-a::after{content:'';position:absolute;bottom:0;left:10px;right:10px;height:2px;background:var(--gold);transform:scaleX(0);transition:transform .2s;border-radius:2px 2px 0 0;}
