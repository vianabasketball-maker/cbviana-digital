#cbv-nav-inner{max-width:1400px;margin:0 auto;height:60px;display:flex;align-items:center;padding:0 20px;gap:8px;}

/* Logo */
.cbv-logo{flex-shrink:0;display:flex;align-items:center;text-decoration:none;margin-right:16px;}
.cbv-logo img{height:44px;width:auto;}
