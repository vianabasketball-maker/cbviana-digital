.cbv-top-contacts{display:flex;align-items:center;gap:16px;}
.cbv-top-a{display:flex;align-items:center;gap:4px;font-family:var(--font);font-size:11px;letter-spacing:.5px;color:rgba(255,255,255,0.45);text-decoration:none;}
.cbv-top-a:hover{color:var(--gold);}
.cbv-top-social{display:flex;align-items:center;gap:12px;}
.cbv-top-social a{color:rgba(255,255,255,0.4);display:flex;align-items:center;transition:color .2s;}
.cbv-top-social a:hover{color:var(--gold);}

/* Menu principal */
#cbv-nav{position:fixed;top:32px;left:0;right:0;z-index:9998;height:60px;background:var(--bordo);border-bottom:2px solid var(--gold);box-shadow:0 2px 20px rgba(0,0,0,0.4);}
body{padding-top:92px!important;}
body.admin-bar #cbv-top{top:32px;}
body.admin-bar #cbv-nav{top:64px;}
body.admin-bar{padding-top:124px!important;}
