@keyframes cbvCircle{0%{stroke-dashoffset:188.5;}50%{stroke-dashoffset:90;}80%{stroke-dashoffset:35;}100%{stroke-dashoffset:0;}}
.cbv-ldr-pct{position:relative;z-index:1;font-family:var(--font);font-size:16px;font-weight:700;color:#fff;}
