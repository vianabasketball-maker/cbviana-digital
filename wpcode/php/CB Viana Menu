<script>
(function(){
  var top=document.getElementById('cbv-top');
  var nav=document.getElementById('cbv-nav');
  var ov=document.getElementById('cbv-overlay');
  var dr=document.getElementById('cbv-drawer');
  var b=document.body;
  if(top) b.insertBefore(top,b.firstChild);
  if(nav) b.insertBefore(nav,top?top.nextSibling:b.firstChild);

  var ham=document.getElementById('cbv-ham');
  var cls=document.getElementById('cbv-close');
  function open(){dr.classList.add('open');ov.classList.add('on');ham.classList.add('open');b.style.overflow='hidden';}
  function close(){dr.classList.remove('open');ov.classList.remove('on');ham.classList.remove('open');b.style.overflow='';}
  if(ham) ham.addEventListener('click',open);
  if(cls) cls.addEventListener('click',close);
  if(ov)  ov.addEventListener('click',close);
  document.addEventListener('keydown',function(e){if(e.key==='Escape'){close();cbvFecharCaderneta();cbvFecharApostas();}});

  document.querySelectorAll('.cbv-sub-list').forEach(function(ul){ul.style.display='none';});
  document.addEventListener('click',function(e){
    var li=e.target.closest('.cbv-drawer-item');
    if(li&&li.classList.contains('open')){
      var sub=li.querySelector('.cbv-sub-list');
      if(sub) sub.style.display=sub.style.display==='none'?'block':'none';
    }
  });

  var pct=document.getElementById('cbv-pct');
  if(pct){
    var s=Date.now();
    (function tick(){
      var p=Math.min((Date.now()-s)/1500,1);
      var e=p<.5?2*p*p:-1+(4-2*p)*p;
      pct.textContent=Math.floor(e*100)+'%';
      if(p<1) requestAnimationFrame(tick);
    })();
  }
})();

function cbvAbrirCaderneta(e){
  if(e) e.preventDefault();
  var ov=document.getElementById('cbv-cad-overlay');
  if(ov){ov.classList.add('on');document.body.style.overflow='hidden';}
  var dr=document.getElementById('cbv-drawer');var no=document.getElementById('cbv-overlay');var h=document.getElementById('cbv-ham');
  if(dr)dr.classList.remove('open');if(no)no.classList.remove('on');if(h)h.classList.remove('open');
}
function cbvFecharCaderneta(){
  var ov=document.getElementById('cbv-cad-overlay');
  if(ov){ov.classList.remove('on');document.body.style.overflow='';}
}

function cbvAbrirApostas(e){
  if(e) e.preventDefault();
  var ov=document.getElementById('cbv-ap-overlay');
  if(ov){ov.classList.add('on');document.body.style.overflow='hidden';}
  var dr=document.getElementById('cbv-drawer');var no=document.getElementById('cbv-overlay');var h=document.getElementById('cbv-ham');
  if(dr)dr.classList.remove('open');if(no)no.classList.remove('on');if(h)h.classList.remove('open');
}
function cbvFecharApostas(){
  var ov=document.getElementById('cbv-ap-overlay');
  if(ov){ov.classList.remove('on');document.body.style.overflow='';}
}
document.addEventListener('click',function(e){
  var ov=document.getElementById('cbv-ap-overlay');
  if(ov&&ov.classList.contains('on')&&e.target===ov) cbvFecharApostas();
  var ov2=document.getElementById('cbv-cad-overlay');
  if(ov2&&ov2.classList.contains('on')&&e.target===ov2) cbvFecharCaderneta();
});
</script>

