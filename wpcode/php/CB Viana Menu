#cbv-nav-inner{max-width:1400px;margin:0 auto;height:60px;display:flex;align-items:center;padding:0 20px;gap:8px;}

/* Logo */
.cbv-logo{flex-shrink:0;display:flex;align-items:center;text-decoration:none;margin-right:16px;}
.cbv-logo img{height:44px;width:auto;}
.cbv-logo-txt{font-family:var(--font);font-size:22px;font-weight:700;letter-spacing:3px;color:var(--gold);}
.cbv-logo-txt span{color:#fff;}

/* Itens menu */
.cbv-menu{list-style:none;margin:0;padding:0;display:flex;align-items:center;flex:1;justify-content:center;}
.cbv-menu li{position:relative;}
.cbv-menu-a{font-family:var(--font);font-size:13px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.75);text-decoration:none;padding:0 10px;height:60px;display:flex;align-items:center;white-space:nowrap;position:relative;transition:color .2s;}
.cbv-menu-a::after{content:'';position:absolute;bottom:0;left:10px;right:10px;height:2px;background:var(--gold);transform:scaleX(0);transition:transform .2s;border-radius:2px 2px 0 0;}
.cbv-menu li:hover>.cbv-menu-a,.cbv-menu li.cur>.cbv-menu-a{color:var(--gold);}
.cbv-menu li:hover>.cbv-menu-a::after,.cbv-menu li.cur>.cbv-menu-a::after{transform:scaleX(1);}
.cbv-menu li.special>.cbv-menu-a{background:var(--gold);color:var(--bordo-dk);border-radius:6px;height:36px;padding:0 14px;margin:0 4px;font-weight:700;}
.cbv-menu li.special>.cbv-menu-a::after{display:none;}
.cbv-menu li.special>.cbv-menu-a:hover{background:#ffbe20;}

/* Item Ajuda-nos a Crescer */
.cbv-menu li.ajuda>.cbv-menu-a{
  color:rgba(255,255,255,0.8);
  background:rgba(26,92,58,0.5);
  border-radius:6px;
  height:34px;
  padding:0 14px;
  margin:0 4px;
  font-weight:700;
  transition:all .2s;
}
.cbv-menu li.ajuda>.cbv-menu-a:hover{
  background:rgba(26,92,58,0.75);
  color:#fff;
}
.cbv-menu li.ajuda>.cbv-menu-a::after{display:none;}

/* Item Caderneta */
.cbv-menu li.caderneta>.cbv-menu-a{color:var(--bordo-dk);background:var(--gold);border-radius:6px;height:36px;padding:0 14px;margin:0 4px;font-weight:700;animation:cadPulse 2s ease-in-out infinite;}
@keyframes cadPulse{0%,100%{box-shadow:0 0 0 0 rgba(240,165,0,0.5);}50%{box-shadow:0 0 12px 4px rgba(240,165,0,0.35);}}
.cbv-menu li.caderneta>.cbv-menu-a::after{display:none;}
.cbv-menu li.caderneta>.cbv-menu-a:hover{background:#ffbe20;}
.cbv-drawer-item.caderneta .cbv-drawer-a{color:var(--gold);font-weight:700;}

/* Item Apostas Beta */
.cbv-menu li.apostas-beta>.cbv-menu-a{position:relative;overflow:hidden;color:#fff;background:#1a4a8a;border-radius:6px;height:34px;padding:0 30px 0 12px!important;margin:0 4px;font-weight:700;transition:all .2s;box-shadow:0 0 10px rgba(26,74,138,0.4);}
.cbv-menu li.apostas-beta>.cbv-menu-a::after{display:none;}
.cbv-menu li.apostas-beta:hover>.cbv-menu-a{background:#1e5cad;box-shadow:0 0 16px rgba(26,74,138,0.6);}
.cbv-menu li.apostas-beta>.cbv-menu-a::before{content:'BETA';position:absolute;top:6px;right:-9px;background:var(--gold);color:var(--bordo-dk);font-size:6px;font-weight:700;letter-spacing:1px;padding:1.5px 12px;transform:rotate(35deg);font-family:var(--font);line-height:1.6;pointer-events:none;z-index:1;}
.cbv-drawer-item.apostas-beta .cbv-drawer-a{position:relative;padding-right:70px!important;color:#7ab3f0;}
.cbv-drawer-item.apostas-beta .cbv-drawer-a::after{content:'BETA';position:absolute;right:20px;top:50%;transform:translateY(-50%);background:var(--gold);color:var(--bordo-dk);font-size:8px;font-weight:700;letter-spacing:1.5px;padding:2px 7px;border-radius:4px;font-family:var(--font);}

/* Dropdown submenu */
.cbv-menu li.has-sub{position:relative;}
.cbv-menu li.has-sub>.cbv-menu-a::after{content:'▾';position:static;display:inline;background:none;transform:none;font-size:10px;margin-left:4px;color:inherit;height:auto;width:auto;border-radius:0;padding:0;letter-spacing:0;transition:transform .2s;}
.cbv-menu li.has-sub:hover>.cbv-menu-a::after{transform:rotate(180deg);}
.cbv-submenu{display:none;position:absolute;top:100%;left:0;min-width:200px;background:#3a0e1c;border:1px solid rgba(240,165,0,0.2);border-top:2px solid var(--gold);border-radius:0 0 8px 8px;padding:6px 0;box-shadow:0 8px 24px rgba(0,0,0,0.5);z-index:100;}
.cbv-menu li.has-sub:hover>.cbv-submenu{display:block;}
.cbv-submenu a{display:block;font-family:var(--font);font-size:12px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.7);text-decoration:none;padding:9px 16px;transition:all .15s;white-space:nowrap;}
.cbv-submenu a:hover{color:var(--gold);background:rgba(240,165,0,0.08);padding-left:20px;}

/* Utilizador */
.cbv-user{display:flex;align-items:center;gap:8px;flex-shrink:0;margin-left:8px;}
.cbv-user img{border-radius:50%;border:1.5px solid var(--gold);width:28px;height:28px;}
.cbv-user-info{display:flex;flex-direction:column;}
.cbv-user-name{font-family:var(--font);font-size:12px;font-weight:600;letter-spacing:1px;color:rgba(255,255,255,0.8);text-decoration:none;line-height:1.3;}
.cbv-user-name:hover{color:var(--gold);}
.cbv-user-out{font-family:var(--font);font-size:10px;letter-spacing:1px;color:rgba(240,165,0,0.5);text-decoration:none;line-height:1.3;}
.cbv-user-out:hover{color:var(--gold);}
.cbv-login{font-family:var(--font);font-size:12px;font-weight:600;letter-spacing:1.5px;text-transform:uppercase;color:rgba(255,255,255,0.6);text-decoration:none;border:1px solid rgba(255,255,255,0.2);border-radius:6px;padding:6px 12px;transition:all .2s;}
.cbv-login:hover{color:var(--gold);border-color:var(--gold);}

/* Hamburger */
.cbv-ham{display:none;flex-direction:column;gap:5px;background:none;border:1px solid rgba(240,165,0,0.3);border-radius:8px;padding:9px;cursor:pointer;width:40px;height:40px;align-items:center;justify-content:center;}
.cbv-ham span{display:block;width:18px;height:2px;background:var(--gold);border-radius:2px;transition:all .3s;}
.cbv-ham.open span:nth-child(1){transform:translateY(7px) rotate(45deg);}
.cbv-ham.open span:nth-child(2){opacity:0;}
.cbv-ham.open span:nth-child(3){transform:translateY(-7px) rotate(-45deg);}

/* Mobile */
@media(max-width:900px){
  .cbv-menu{display:none;}
  .cbv-ham{display:flex;}
