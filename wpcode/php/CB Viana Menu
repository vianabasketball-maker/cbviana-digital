<style id="cbv-nav-styles">
@import url('https://fonts.googleapis.com/css2?family=Teko:wght@600;700&display=swap');
:root{--bordo:#7B1C2E;--bordo-dk:#5a1220;--gold:#F0A500;--font:'Teko','Barlow Condensed',sans-serif;}

/* Esconder menu original do tema */
.is-head-menu,.wp-block-navigation.is-head-menu,nav.wp-block-navigation{display:none!important;}

/* Topbar */
#cbv-top{position:fixed;top:0;left:0;right:0;z-index:9999;height:32px;background:var(--bordo-dk);border-bottom:1px solid rgba(240,165,0,0.15);display:flex;align-items:center;}
