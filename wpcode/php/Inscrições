add_shortcode('cbv_inscricoes', function(){

  // ── Calcular escalão pelo ano de nascimento ──
  $escaloes = [
    2023 => 'Baby Basket (2023)',
    2022 => 'Baby Basket (2022)',
    2021 => 'Mini-8 (2021)',
    2020 => 'Mini-8 (2020)',
    2019 => 'Mini-10 (2019)',
    2018 => 'Mini-10 (2018)',
    2017 => 'Mini-12 (2017)',
    2016 => 'Mini-12 (2016)',
    2015 => 'Sub-14 (2015)',
    2014 => 'Sub-14 (2014)',
    2013 => 'Sub-16 (2013)',
    2012 => 'Sub-16 (2012)',
    2011 => 'Sub-18 (2011)',
    2010 => 'Sub-18 (2010)',
  ];

  // ── Processar formulário ──
  $success = false;
  $error   = '';

  if(isset($_POST['cbv_insc_submit']) && wp_verify_nonce($_POST['cbv_insc_nonce'], 'cbv_inscricao')){
    $nome      = sanitize_text_field($_POST['nome'] ?? '');
    $apelido   = sanitize_text_field($_POST['apelido'] ?? '');
    $dob       = sanitize_text_field($_POST['data_nascimento'] ?? '');
    $tel       = sanitize_text_field($_POST['telefone'] ?? '');
    $email     = sanitize_email($_POST['email'] ?? '');
    $primeira  = isset($_POST['primeira_vez']) ? 'Sim' : 'Não';
    $clube_ant = sanitize_text_field($_POST['clube_anterior'] ?? '');
    $obs       = sanitize_textarea_field($_POST['observacoes'] ?? '');

    // Dados pais (se menor)
    $ano_nasc  = (int)date('Y', strtotime($dob));
    $idade     = date('Y') - $ano_nasc;
    $menor     = $idade < 18;

    $pai_nome  = sanitize_text_field($_POST['pai_nome'] ?? '');
    $pai_tel   = sanitize_text_field($_POST['pai_tel'] ?? '');
    $pai_email = sanitize_email($_POST['pai_email'] ?? '');

    // Determinar escalão
    $escalao = $escaloes[$ano_nasc] ?? ($ano_nasc >= 2009 ? 'Sénior' : 'Verificar com a direcção');

    if(!$nome || !$apelido || !$dob || !$tel || !$email){
      $error = 'Por favor preenche todos os campos obrigatórios.';
    } elseif(!is_email($email)){
      $error = 'Email inválido.';
    } else {
      // Enviar email
      $to      = 'vianabasketball@gmail.com';
      $subject = 'Pedido de Inscrição — ' . $nome . ' ' . $apelido;

      $msg  = "PEDIDO DE INSCRIÇÃO — CB VIANA\n";
      $msg .= str_repeat('=', 40) . "\n\n";
      $msg .= "DADOS DO ATLETA\n";
      $msg .= "Nome: $nome $apelido\n";
      $msg .= "Data de Nascimento: $dob\n";
      $msg .= "Escalão: $escalao\n";
      $msg .= "Telefone: $tel\n";
      $msg .= "Email: $email\n";
      $msg .= "Primeira vez no basquetebol: $primeira\n";
      if(!$primeira && $clube_ant) $msg .= "Clube anterior: $clube_ant\n";
      if($obs) $msg .= "Observações: $obs\n";

      if($menor){
        $msg .= "\nDADOS DO ENCARREGADO DE EDUCAÇÃO\n";
        $msg .= "Nome: $pai_nome\n";
        $msg .= "Telefone: $pai_tel\n";
        $msg .= "Email: $pai_email\n";
      }

      $headers = ['Content-Type: text/plain; charset=UTF-8', 'From: CB Viana <noreply@cbviana.com>'];
      if($email) $headers[] = 'Reply-To: ' . $nome . ' ' . $apelido . ' <' . $email . '>';

      $sent = wp_mail($to, $subject, $msg, $headers);

      if($sent){
        // Email de confirmação ao atleta/encarregado
        $reply_to = $menor && $pai_email ? $pai_email : $email;
        $reply_name = $menor && $pai_nome ? $pai_nome : "$nome $apelido";
        $conf_msg  = "Olá $reply_name,\n\n";
        $conf_msg .= "Recebemos o teu pedido de inscrição para $nome $apelido no CB Viana.\n\n";
        $conf_msg .= "Escalão previsto: $escalao\n\n";
        $conf_msg .= "Em breve entraremos em contacto com todas as informações necessárias.\n\n";
        $conf_msg .= "Obrigado pelo interesse no Clube Basquete Viana!\n\n";
        $conf_msg .= "CB Viana\ncbasqueteviana@gmail.com\n+351 917 815 629";
        wp_mail($reply_to, 'Pedido de Inscrição recebido — CB Viana', $conf_msg, $headers);
        $success = true;
      } else {
        $error = 'Erro ao enviar. Por favor contacta-nos por email ou telefone.';
      }
    }
  }

  ob_start();
