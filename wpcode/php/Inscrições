  <script>
  (function(){
    var escaloes = {
      2023:'Baby Basket',2022:'Baby Basket',
      2021:'Mini-8',2020:'Mini-8',
      2019:'Mini-10',2018:'Mini-10',
      2017:'Mini-12',2016:'Mini-12',
      2015:'Sub-14',2014:'Sub-14',
      2013:'Sub-16',2012:'Sub-16',
      2011:'Sub-18',2010:'Sub-18',
      2009:'Sénior',2008:'Sénior',2007:'Sénior'
    };

    var dob = document.getElementById('cbv-dob');
    var esc = document.getElementById('cbv-escalao');
    var menorSec = document.getElementById('cbv-menor-section');
    var primeiraCheck = document.getElementById('cbv-primeira');
    var clubeRow = document.getElementById('cbv-clube-row');

    function updateEscalao(){
      if(!dob.value) return;
      var ano = new Date(dob.value).getFullYear();
      var nome = escaloes[ano] || (ano >= 2006 ? 'Sénior' : 'Verificar com a direcção');
      esc.textContent = '🏀 ' + nome + ' (' + ano + ')';
      esc.style.display = 'block';
      // Mostrar secção encarregado se menor
      var idade = new Date().getFullYear() - ano;
      if(idade < 18){
        menorSec.style.display = 'block';
      } else {
        menorSec.style.display = 'none';
      }
    }

    if(dob){ dob.addEventListener('change', updateEscalao); updateEscalao(); }

    // Mostrar clube anterior se não é primeira vez
    if(primeiraCheck){
      primeiraCheck.addEventListener('change', function(){
        clubeRow.style.display = this.checked ? 'none' : 'grid';
      });
      clubeRow.style.display = primeiraCheck.checked ? 'none' : 'grid';
    }
  })();
  </script>
