<script>
var cvd=null, cvnonce='<?php echo esc_js($nonce); ?>';

function cvTab(n,btn){
  document.querySelectorAll('.cbv-tab').forEach(function(b){b.classList.remove('active');});
  btn.classList.add('active');
  ['a','j','u'].forEach(function(t){
    var p=document.getElementById('cp-'+t);
    if(p) p.style.display=t===n?'block':'none';
  });
}

function mk(tag,css,txt){
  var e=document.createElement(tag);
  if(css) e.style.cssText=css;
  if(txt!==undefined) e.textContent=txt;
  return e;
}

function mkTable(heads,rows){
  var t=document.createElement('table');
  t.className='ct';
  t.innerHTML='<thead><tr>'+heads.map(function(h){return '<th>'+h+'</th>';}).join('')+'</tr></thead><tbody>'+rows.join('')+'</tbody>';
  return t;
}

function renderApostas(){
  var a=cvd.apostas, p=document.getElementById('cp-a');
  if(!p||p.dataset.ok) return;
  p.dataset.ok='1';

  // Cards
  var cards=mk('div');cards.className='cbv-cards';
  [[a.total,'Total'],[a.pendentes,'Pendentes'],[a.ganhas,'Ganhas'],[a.perdidas,'Perdidas'],[a.moedas_pagas+' mds','Pagas'],[a.moedas_risco+' mds','Em Jogo']].forEach(function(r){
    var c=mk('div');c.className='cbv-card';
    var v=mk('div','font-size:28px;font-weight:700;color:#7B1C2E;');v.textContent=r[0];
    var l=mk('div','font-size:11px;color:#666;margin-top:4px;',r[1]);
    c.appendChild(v);c.appendChild(l);cards.appendChild(c);
  });
  p.appendChild(cards);

  // Top jogos
  p.appendChild(mk('div','font-size:15px;font-weight:600;margin:20px 0 10px;','Jogos mais apostados'));
  p.appendChild(mkTable(['Jogo','Apostas'],Object.entries(a.top_jogos).map(function(e){
    return '<tr><td>'+e[0]+'</td><td><strong>'+e[1]+'</strong></td></tr>';
  })));

  // Por utilizador
  p.appendChild(mk('div','font-size:15px;font-weight:600;margin:20px 0 10px;','Por Utilizador'));
  p.appendChild(mkTable(['Utilizador','Total','Pendentes','Ganhas','Perdidas','Apostado','Ganho'],a.por_user.map(function(u){
    return '<tr>'+
      '<td><strong style="cursor:pointer;color:#7B1C2E;text-decoration:underline;" class="cvfu" data-u="'+u.username+'">'+u.username+'</strong></td>'+
      '<td>'+u.total+'</td>'+
      '<td>'+(u.pendentes>0?'<span class="bge bg-gold">'+u.pendentes+'</span>':'0')+'</td>'+
      '<td><span class="bge bg-gr">'+u.ganhas+'</span></td>'+
      '<td><span class="bge bg-rd">'+u.perdidas+'</span></td>'+
      '<td>'+u.moedas_apostadas+' mds</td>'+
      '<td>'+u.moedas_ganhas+' mds</td></tr>';
  })));

  // Botao enriquecer
  var dv=mk('div','margin:12px 0;padding:10px 14px;background:#fff8e1;border-radius:8px;border:1px solid #f0a500;display:flex;align-items:center;justify-content:space-between;');
  dv.appendChild(mk('span','font-size:12px;color:#7B1C2E;','Apostas sem dados podem ser atualizadas'));
  var be=mk('button','background:#F0A500;color:#1a0810;border:none;border-radius:6px;padding:6px 14px;font-size:12px;font-weight:600;cursor:pointer;','Atualizar dados');
  be.addEventListener('click',enricher);
  dv.appendChild(be);p.appendChild(dv);

  // Titulo + filtro
  var st=mk('div','font-size:15px;font-weight:600;margin:20px 0 10px;');
  st.innerHTML='Apostas <span id="flbl" style="color:#7B1C2E;font-size:13px;"></span>';
  var bl=mk('button','display:none;background:#7B1C2E;color:#F0A500;border:none;border-radius:6px;padding:3px 10px;cursor:pointer;font-size:11px;margin-left:8px;','x Todos');
  bl.id='btn-bl';bl.addEventListener('click',function(){filtrar('');});
  st.appendChild(bl);p.appendChild(st);

  var df=mk('div','margin-bottom:10px;display:flex;gap:8px;align-items:center;');
  var sel=document.createElement('select');
  sel.id='fsel';sel.style.cssText='padding:6px 10px;border:1px solid #ddd;border-radius:6px;font-size:12px;';
  sel.innerHTML='<option value="">Todos os utilizadores</option>'+a.por_user.map(function(u){return '<option value="'+u.username+'">'+u.username+' ('+u.total+')</option>';}).join('');
  sel.addEventListener('change',function(){filtrar(this.value);});
  var sp=mk('span','font-size:12px;color:#666;');sp.id='ftot';
  df.appendChild(sel);df.appendChild(sp);p.appendChild(df);

  var tbl=document.createElement('table');tbl.className='ct';tbl.id='ftbl';
  tbl.innerHTML='<thead><tr><th>Utilizador</th><th>Jogo</th><th>Escolha</th><th>Montante</th><th>Estado</th><th>Data</th></tr></thead><tbody id="ftbody"></tbody>';
  p.appendChild(tbl);

  p.addEventListener('click',function(e){if(e.target.classList.contains('cvfu'))filtrar(e.target.dataset.u);});
  window._ap=a.lista;
  setTimeout(function(){filtrar('');},50);
}

function filtrar(u){
  var all=window._ap||[];
  var fil=u?all.filter(function(a){return a.username===u;}):all;
  var show=fil.slice(0,u?20:50);
  var lb=document.getElementById('flbl');
  var bl=document.getElementById('btn-bl');
  var sel=document.getElementById('fsel');
  var tot=document.getElementById('ftot');
  var tb=document.getElementById('ftbody');
  if(lb) lb.textContent=u?'— '+u:'';
  if(bl) bl.style.display=u?'inline-block':'none';
  if(sel) sel.value=u;
  if(tot) tot.textContent='A mostrar '+show.length+' de '+fil.length;
  if(!tb) return;
  tb.innerHTML=show.map(function(ap){
    var bg=ap.estado==='ganha'?'bg-gr':ap.estado==='perdida'?'bg-rd':ap.estado==='pendente'?'bg-gold':'bg-gy';
    var ts=ap.sigla_casa&&ap.sigla_fora;
    var jogo=ts?(ap.sigla_casa+' vs '+ap.sigla_fora):(ap.comp||(ap.data?'Aposta '+ap.data:'Aposta anterior'));
    var esc=ap.escolha==='casa'?(ap.sigla_casa||'Casa'):(ap.sigla_fora||'Fora');
    var dt=new Date(ap.criada_em*1000).toLocaleString('pt-PT');
    return '<tr><td><strong>'+ap.username+'</strong></td><td>'+jogo+'</td><td>'+esc+'</td><td>'+ap.montante+' mds</td><td><span class="bge '+bg+'">'+ap.estado.toUpperCase()+'</span></td><td>'+dt+'</td></tr>';
  }).join('');
}

function enricher(){
  fetch('/wp-json/cbv/v1/apostas/enriquecer',{method:'POST',credentials:'include',headers:{'X-WP-Nonce':cvnonce}})
  .then(function(r){return r.json();})
  .then(function(d){
    if(d.sucesso){alert('Atualizadas: '+d.atualizadas+' de '+d.total);location.reload();}
    else alert('Erro ao atualizar');
  }).catch(function(){alert('Erro de ligacao');});
}

function renderJogos(){
