    })));
  });
}

function renderUsers(){
  var us=cvd.users,p=document.getElementById('cp-u');
  if(!p||p.dataset.ok) return;p.dataset.ok='1';
  var tm=us.reduce(function(s,u){return s+u.moedas;},0);
  var cards=mk('div');cards.className='cbv-cards';
  [[us.length,'Utilizadores'],[tm+' mds','Moedas Circulacao']].forEach(function(r){
