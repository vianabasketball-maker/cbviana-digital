add_action('rest_api_init', function() {
    register_rest_route('cbv/v1', '/admin/stats', [
        'methods'             => 'GET',
        'permission_callback' => function(){ return current_user_can('manage_options'); },
        'callback'            => function() {
            $apostas = get_option('cbv_apostas_v1', []);

            $jogos_count = [];
            $por_user    = [];
            foreach ($apostas as $a) {
                $sc  = $a['sigla_casa'] ?? '';
                $sf  = $a['sigla_fora'] ?? '';
                $key = ($sc && $sf) ? ($sc.' vs '.$sf) : ('Sem dados ('.date('M Y',$a['criada_em']).')');
                $jogos_count[$key] = ($jogos_count[$key] ?? 0) + 1;
                $uid = $a['uid'];
                if (!isset($por_user[$uid])) $por_user[$uid] = ['uid'=>$uid,'username'=>$a['username']??'','total'=>0,'pendentes'=>0,'ganhas'=>0,'perdidas'=>0,'moedas_apostadas'=>0,'moedas_ganhas'=>0];
                $por_user[$uid]['total']++;
                if ($a['estado']==='pendente') $por_user[$uid]['pendentes']++;
                if ($a['estado']==='ganha')  { $por_user[$uid]['ganhas']++;  $por_user[$uid]['moedas_ganhas']    += $a['payout']??0; }
                if ($a['estado']==='perdida')  $por_user[$uid]['perdidas']++;
                $por_user[$uid]['moedas_apostadas'] += $a['montante']??0;
            }
            arsort($jogos_count);
            usort($por_user, fn($a,$b) => $b['total']-$a['total']);

            $scores_raw = get_option('cbv_scores',[]);
            if (empty($scores_raw)) $scores_raw = get_option('cbv_scores_v1',[]);
            if (empty($scores_raw)) { $req=new WP_REST_Request('GET','/cbv/v1/scores'); $res=rest_do_request($req); $scores_raw=$res->get_data()?:[]; }
            $jogos_stats = [];
            foreach ($scores_raw as $gid => $entries) {
                if (!is_array($entries)) continue;
                usort($entries, fn($a,$b)=>($b['score']??0)-($a['score']??0));
                $jogos_stats[$gid] = ['jogo'=>$gid,'jogadores'=>count($entries),'top_score'=>!empty($entries)?max(array_column($entries,'score')):0,'top_player'=>$entries[0]['username']??'','entries'=>array_slice($entries,0,5)];
            }

            $users_data = [];
            foreach (get_users(['fields'=>['ID','display_name','user_email','user_registered']]) as $u) {
                $users_data[] = ['uid'=>$u->ID,'nome'=>$u->display_name,'email'=>$u->user_email,'moedas'=>(int)get_user_meta($u->ID,'cbv_moedas',true),'acessos'=>(int)get_user_meta($u->ID,'cbv_acessos',true),'nivel'=>(int)get_user_meta($u->ID,'cbv_nivel',true),'registado'=>date('d/m/Y',strtotime($u->user_registered))];
            }
            usort($users_data, fn($a,$b)=>$b['moedas']-$a['moedas']);

            $pend  = count(array_filter($apostas,fn($a)=>$a['estado']==='pendente'));
            $ganh  = count(array_filter($apostas,fn($a)=>$a['estado']==='ganha'));
            $perd  = count(array_filter($apostas,fn($a)=>$a['estado']==='perdida'));
            $mpag  = array_sum(array_column(array_filter($apostas,fn($a)=>$a['estado']==='ganha'),'payout'));
            $mrisco= array_sum(array_column(array_filter($apostas,fn($a)=>$a['estado']==='pendente'),'montante'));

            return rest_ensure_response([
                'apostas'=>['total'=>count($apostas),'pendentes'=>$pend,'ganhas'=>$ganh,'perdidas'=>$perd,'moedas_pagas'=>$mpag,'moedas_risco'=>$mrisco,'top_jogos'=>array_slice($jogos_count,0,5,true),'por_user'=>array_values($por_user),'lista'=>array_reverse($apostas)],
                'jogos'=>$jogos_stats,
                'users'=>$users_data,
            ]);
        },
    ]);
});

